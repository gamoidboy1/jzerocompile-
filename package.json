{
  "name": "jzerocompiler",
  "version": "1.0.0",
  "description": "JzeroCompiler",
  "author": "Jzero",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "app": "electron .",
    "pack": "electron-packager . JzeroCompiler --platform=win32 --arch=x64 --out=\"../PROJECT BUILDS\" --overwrite --icon=public/assets/logo.ico --prune=true --asar --ignore=\"^/build($|/)\" --ignore=\"^/README\\.md$\" --ignore=\"^/Start_JzeroCompile\\.bat$\" --ignore=\"^/\\.gitignore$\"",
    "build": "electron-builder build --win",
    "build-exe": "npx pkg server.js --assets \"public/**/*\" --targets node18-win-x64 --output JzeroCompiler.exe"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "split.js": "^1.6.5"
  },
  "build": {
    "appId": "com.jzero.compiler",
    "productName": "JzeroCompiler",
    "directories": {
      "output": "build"
    },
    "win": {
      "target": "portable",
      "icon": "public/assets/logo.png",
      "artifactName": "${productName}.${ext}",
      "publish": null
    },
    "files": [
      "**/*",
      "!build/*",
      "!dist/*",
      "!*.ps1",
      "!*.bat",
      "!README.md"
    ]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  }
}
