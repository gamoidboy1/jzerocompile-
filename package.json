{
  "name": "god-c-compiler",
  "version": "1.0.0",
  "description": "God Tier Light UI for C Compiler",
  "author": "Jzero",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "app": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.8.3",
    "split.js": "^1.6.5"
  },
  "build": {
    "appId": "com.jzero.compile",
    "productName": "JzeroCompile",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "public/assets/logo.png"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
